#: includes/class-bp-activity-filter-admin.php:204
msgid "Default Filters"
msgstr "Filtres par défaut"

#: includes/class-bp-activity-filter-admin.php:208
msgid "Hidden Activities"
msgstr "Activités CPT"

#: includes/class-bp-activity-filter-admin.php:212
