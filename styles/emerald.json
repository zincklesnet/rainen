{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Emerald",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "base",       "color": "#F6FEF9", "name": "Base" },
				{ "slug": "base-2",     "color": "#ECFDF5", "name": "Base 2" },
				{ "slug": "base-3",     "color": "#D1FAE5", "name": "Base 3" },
				{ "slug": "contrast",   "color": "#052E16", "name": "Contrast" },
				{ "slug": "contrast-2", "color": "#14532D", "name": "Contrast 2" },
				{ "slug": "contrast-3", "color": "#4D7C5A", "name": "Contrast 3" },
				{ "slug": "accent",     "color": "#047857", "name": "Emerald" },
				{ "slug": "accent-2",   "color": "#059669", "name": "Spring" },
				{ "slug": "accent-3",   "color": "#0D9488", "name": "Teal" },
				{ "slug": "surface-1",  "color": "#ECFDF5", "name": "Surface Mint" },
				{ "slug": "surface-2",  "color": "#F0FDFA", "name": "Surface Aqua" },
				{ "slug": "surface-3",  "color": "#064E3B", "name": "Surface Dark" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--accent)" },
				":hover": { "color": { "text": "var(--wp--preset--color--accent-2)" } }
			}
		}
	}
}
