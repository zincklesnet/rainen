{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Indigo",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "base",       "color": "#FAFAFF", "name": "Base" },
				{ "slug": "base-2",     "color": "#F1F1FB", "name": "Base 2" },
				{ "slug": "base-3",     "color": "#E0E0F5", "name": "Base 3" },
				{ "slug": "contrast",   "color": "#1B1834", "name": "Contrast" },
				{ "slug": "contrast-2", "color": "#3730A3", "name": "Contrast 2" },
				{ "slug": "contrast-3", "color": "#565178", "name": "Contrast 3" },
				{ "slug": "accent",     "color": "#4F46E5", "name": "Indigo" },
				{ "slug": "accent-2",   "color": "#4338CA", "name": "Royal" },
				{ "slug": "accent-3",   "color": "#7C3AED", "name": "Violet" },
				{ "slug": "surface-1",  "color": "#EEF2FF", "name": "Surface Mist" },
				{ "slug": "surface-2",  "color": "#F5F3FF", "name": "Surface Lilac" },
				{ "slug": "surface-3",  "color": "#1E1B4B", "name": "Surface Dark" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--accent)" },
				":hover": { "color": { "text": "var(--wp--preset--color--accent-2)" } }
			}
		}
	}
}
